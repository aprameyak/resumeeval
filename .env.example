# =============================================================================
# ResumeScore Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Database
DATABASE_URL=postgresql://resumescore:password@localhost:5432/resumescore
POSTGRES_PASSWORD=password
POSTGRES_USER=resumescore
POSTGRES_DB=resumescore

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth (JWT)
SECRET_KEY=your-super-secret-key-min-32-chars-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage backend: "local" for dev, "s3" for production
STORAGE_BACKEND=local
LOCAL_UPLOAD_PATH=./uploads
MAX_UPLOAD_SIZE_MB=10

# AWS S3 (only needed if STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=resumescore-uploads
S3_ENDPOINT_URL=

# AI / Hiring Agent Engine
# Supported: gemini-2.0-flash, gemini-2.5-flash, gemini-2.5-pro, gemma3:4b (local)
GEMINI_API_KEY=
DEFAULT_MODEL=gemini-2.0-flash
LLM_PROVIDER=gemini

# GitHub (for higher rate limits on public API)
GITHUB_TOKEN=

# Hiring Agent path (clone https://github.com/interviewstreet/hiring-agent here)
HIRING_AGENT_PATH=./hiring-agent

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Email (optional - for password reset, verification)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@resumescore.app
